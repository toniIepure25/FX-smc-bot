# ── Forward Paper Trading Service Configuration ──

# Feed mode: "oanda" (live), "file_watch" (CSV drops), or "replay" (testing)
FEED_MODE=oanda

# Data directories (mapped as volumes in docker-compose)
DATA_DIR=/data/real
WATCH_DIR=/data/live
OUTPUT_DIR=/app/forward_runs

# Auto-resume from latest checkpoint on restart
AUTO_RESUME=true

# ── OANDA API (required for oanda mode) ──
# Sign up at https://www.oanda.com/register/#/sign-up/demo
# Then get your API key from https://www.oanda.com/demo-account/tpa/personal_token
OANDA_API_KEY=
OANDA_ACCOUNT_ID=
OANDA_PRACTICE=true

# ── Telegram Alerts (optional but highly recommended) ──
# 1. Message @BotFather on Telegram, send /newbot, follow prompts
# 2. Copy the bot token below
# 3. Message your new bot, then visit:
#    https://api.telegram.org/bot<TOKEN>/getUpdates
# 4. Copy the chat.id number below
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
