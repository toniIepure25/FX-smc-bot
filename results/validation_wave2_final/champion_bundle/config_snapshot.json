{
  "environment": "dev",
  "data": {
    "root_dir": "data",
    "raw_dir": "data/raw",
    "interim_dir": "data/interim",
    "processed_dir": "data/processed",
    "primary_pairs": [
      "EURUSD",
      "GBPUSD",
      "USDJPY"
    ],
    "context_timeframes": [
      "4h",
      "1h"
    ],
    "execution_timeframes": [
      "15m",
      "5m"
    ],
    "timezone": "UTC"
  },
  "structure": {
    "swing_lookback": 5,
    "min_swing_atr_multiple": 0.3,
    "atr_period": 14,
    "fvg_min_atr_multiple": 0.5,
    "fvg_max_fill_pct": 0.5,
    "displacement_atr_multiple": 1.5,
    "displacement_body_efficiency": 0.6,
    "ob_require_displacement": true,
    "equal_level_tolerance_pips": 3.0,
    "equal_level_min_touches": 2
  },
  "sessions": {
    "asian": {
      "start": "00:00:00",
      "end": "08:00:00"
    },
    "london": {
      "start": "07:00:00",
      "end": "16:00:00"
    },
    "new_york": {
      "start": "12:00:00",
      "end": "21:00:00"
    },
    "london_ny_overlap": {
      "start": "12:00:00",
      "end": "16:00:00"
    }
  },
  "risk": {
    "base_risk_per_trade": 0.005,
    "max_portfolio_risk": 0.015,
    "max_daily_drawdown": 0.03,
    "max_weekly_drawdown": 0.06,
    "max_concurrent_positions": 3,
    "max_per_pair_positions": 1,
    "max_usd_directional_exposure": 1.0,
    "min_reward_risk_ratio": 1.5,
    "score_risk_modulation": 0.5,
    "volatility_risk_scaling": true,
    "max_currency_exposure": 2.0,
    "max_directional_concentration": 0.8,
    "max_trades_per_day": 10,
    "max_trades_per_session": 5,
    "daily_loss_lockout": 0.025,
    "consecutive_loss_dampen_after": 3,
    "consecutive_loss_dampen_factor": 0.5,
    "allocation_strategy": "equal_risk"
  },
  "execution": {
    "model_spread": true,
    "model_slippage": true,
    "default_spread_pips": 1.5,
    "slippage_pips": 0.3,
    "latency_ms": 150,
    "allow_limit_orders": true,
    "fill_on_touch": false,
    "fill_policy": "conservative",
    "volatility_slippage_factor": 0.1,
    "volatility_spread_factor": 0.3
  },
  "backtest": {
    "start_date": null,
    "end_date": null,
    "initial_capital": 100000.0,
    "commission_per_lot": 3.5,
    "lot_size": 100000.0
  },
  "alpha": {
    "enabled_families": [
      "sweep_reversal",
      "bos_continuation",
      "fvg_retrace"
    ],
    "scoring_weights": [
      0.5,
      0.3,
      0.2
    ],
    "min_signal_score": 0.15,
    "slippage_model": "fixed",
    "sizer_model": "stop_based"
  },
  "ml": {
    "enable_regime_filter": false,
    "enable_regime_tagging": true,
    "enable_trade_quality_model": false,
    "enable_meta_labeling": false
  },
  "deployment_gate": {
    "min_sharpe": 0.3,
    "min_profit_factor": 1.1,
    "max_drawdown_pct": 0.2,
    "min_trade_count": 30,
    "min_win_rate": 0.35,
    "max_cost_degradation_pct": 0.5,
    "min_stability": 0.3,
    "min_robustness": 0.3,
    "min_oos_consistency": 0.5,
    "min_diversification": 0.2
  }
}